# ============================================================
# HOST APP — set these in Netlify → mfe-host → Environment variables
# ============================================================

# REQUIRED: URLs to your 3 deployed remote sites (replace with your Netlify URLs)
VITE_DASHBOARD_REMOTE=https://YOUR-DASHBOARD.netlify.app/assets/remoteEntry.js
VITE_USER_REMOTE=https://YOUR-USER.netlify.app/assets/remoteEntry.js
VITE_REPORTS_REMOTE=https://YOUR-REPORTS.netlify.app/assets/remoteEntry.js

# REQUIRED for login without a backend API (demo mode)
VITE_DEMO_MODE=true

# Optional — only needed when you have a real backend
VITE_API_BASE_URL=https://your-api.example.com/api
